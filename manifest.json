{
  "manifest_version": 3,
  "name": "Zenified Start Page",
  "version": "1.1.0",
  "description": "A calm, theme-aware new tab page with search, shortcuts, bookmarks, notes, and focus tools.",
  "permissions": [
    "bookmarks",
    "storage",
    "theme"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "48": "icons/zenified.svg",
    "96": "icons/zenified.svg"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; img-src 'self' https: data:; object-src 'none'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "@zenified-start-page.kexfff",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
